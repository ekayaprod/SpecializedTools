{
    "name": "browser-toolkit",
    "version": "1.0.0",
    "description": "A collection of utility bookmarklets for web development and content management.",
    "license": "MIT",
    "keywords": [
        "bookmarklet",
        "browser",
        "automation",
        "tools"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "format": "prettier --write .",
        "lint": "eslint . && tsc --noEmit",
        "pretest": "npm run lint",
        "test": "node scripts/run_tests.js",
        "verify-links": "python3 scripts/verify_links.py"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "c8": "^11.0.0",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.3.0",
        "jsdom": "^29.1.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    }
}
